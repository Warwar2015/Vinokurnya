<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors (Neon Green) -->
    <Color x:Key="PrimaryColor">#00FFAB</Color>
    <Color x:Key="PrimaryDark">#00CC8A</Color>
    <Color x:Key="PrimaryLight">#33FFCC</Color>
    <Color x:Key="PrimaryDarken">#009966</Color>

    <!-- Secondary Colors -->
    <Color x:Key="SecondaryColor">#1A1A2E</Color>
    <Color x:Key="SecondaryLight">#252540</Color>
    <Color x:Key="SecondaryDarken">#0D0D1A</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#00CCFF</Color>
    <Color x:Key="AccentColorDark">#0099CC</Color>

    <!-- Text Colors -->
    <Color x:Key="TextColor">#FFFFFF</Color>
    <Color x:Key="TextColorSecondary">#CCCCCC</Color>
    <Color x:Key="TextColorMuted">#888888</Color>

    <!-- Background Colors -->
    <Color x:Key="BackgroundColor">#1A1A2E</Color>
    <Color x:Key="SurfaceColor">#16213E</Color>
    <Color x:Key="SurfaceLight">#1F2B4D</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#00FFAB</Color>
    <Color x:Key="BorderColorMuted">#333344</Color>

    <!-- Success/Warning/Error Colors -->
    <Color x:Key="SuccessColor">#00FFAB</Color>
    <Color x:Key="WarningColor">#FFD700</Color>
    <Color x:Key="ErrorColor">#FF4444</Color>

    <!-- Opacity Levels -->
    <Double x:Key="OpacityDisabled">0.5</Double>
    <Double x:Key="OpacityHover">0.8</Double>

    <!-- Brush Definitions -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLight}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextColorSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextColorMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderMutedBrush" Color="{StaticResource BorderColorMuted}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

</ResourceDictionary>