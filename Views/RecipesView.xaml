<UserControl x:Class="VinokurnyaWpf.Views.RecipesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:VinokurnyaWpf.ViewModels"
             xmlns:local="clr-namespace:VinokurnyaWpf.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.DataContext>
        <vm:RecipesViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header and Filters -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📖 Рецепты" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Command="{Binding ExportRecipesCommand}"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Margin="15,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Экспорт" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <TextBox Width="300" Text="{Binding SearchQuery, Mode=TwoWay}" 
                        materialDesign:HintAssist.Hint="Поиск рецептов..."
                        Padding="10"/>
                <ComboBox Width="200" ItemsSource="{Binding Categories}" 
                         SelectedItem="{Binding SelectedCategory}" 
                         materialDesign:HintAssist.Hint="Категория"
                         Padding="10"
                         Margin="10,0,0,0"/>

                <ToggleButton IsChecked="{Binding ShowFavoritesOnly}" 
                            Content="Избранное"
                            Style="{DynamicResource MaterialDesignToggleButton}"/>
            </StackPanel>
        </StackPanel>

        <!-- Recipes Grid -->
        <ScrollViewer Grid.Row="1">
            <DataGrid ItemsSource="{Binding FilteredRecipes}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>
                    <DataGridTextColumn Header="Подкатегория" Binding="{Binding Subcategory}" Width="120"/>
                    <DataGridTextColumn Header="Сложность" Width="80">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Difficulty" Converter="{local:DifficultyToStarsConverter}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Время" Binding="{Binding TimeDays}" Width="80"/>
                    <DataGridTextColumn Header="Выход" Binding="{Binding YieldLiters}" Width="80"/>
                    <DataGridTextColumn Header="Рейтинг" Width="80">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Rating" Converter="{local:RatingToStarsConverter}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Отмечено как любимое" Width="150">
                        <DataGridTextColumn.Binding>
                            <Binding Path="IsFavorite" Converter="{local:BoolToTextConverter}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Действия" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}"
                                        Style="{DynamicResource MaterialDesignOutlinedButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="★" VerticalAlignment="Center"/>
                                        <TextBlock Text="Избранное" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <!-- Instructions -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Советы:" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="• Используйте поиск и фильтрацию для быстрого поиска нужных рецептов" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock Text="• Нажмите на любой рецепт для просмотра деталей" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock Text="• Для создания собственных рецептов используйте функцию 'Добавить рецепт'" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>