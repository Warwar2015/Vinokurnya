<UserControl x:Class="VinokurnyaWpf.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:VinokurnyaWpf.ViewModels"
             xmlns:local="clr-namespace:VinokurnyaWpf.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.DataContext>
        <vm:NotesViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header and Filters -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📝 Заметки" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Command="{Binding ExportNotesCommand}"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Margin="15,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Экспорт" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                <TextBox Width="300" Text="{Binding SearchQuery, Mode=TwoWay}" 
                        materialDesign:HintAssist.Hint="Поиск заметок..."
                        Padding="10"/>
                <ComboBox Width="200" ItemsSource="{Binding Stages}" 
                         SelectedItem="{Binding SelectedStage}" 
                         materialDesign:HintAssist.Hint="Этап"
                         Padding="10"
                         Margin="10,0,0,0"/>

                <ToggleButton IsChecked="{Binding ShowFavoritesOnly}" 
                            Content="Избранное"
                            Style="{DynamicResource MaterialDesignToggleButton}"/>
            </StackPanel>
        </StackPanel>

        <!-- Notes Grid -->
        <ScrollViewer Grid.Row="1">
            <DataGrid ItemsSource="{Binding FilteredNotes}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectedItem="{Binding SelectedNote, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Этап" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Stage" Converter="{StaticResource StageToTextConverter}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Теги" Binding="{Binding Tags}" Width="200"/>
                    <DataGridTextColumn Header="Отмечено как любимое" Width="120">
                        <DataGridTextColumn.Binding>
                            <Binding Path="IsFavorite" Converter="{StaticResource BoolToTextConverter}"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Действия" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}"
                                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                                        Margin="0,0,0,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🗑️" VerticalAlignment="Center"/>
                                        <TextBlock Text="Удалить" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>

        <!-- Instructions -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Советы:" FontWeight="Bold" Margin="0,0,0,0"/>
            <TextBlock Text="• Создавайте заметки для каждого этапа процесса самогоноварения" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock Text="• Используйте категории для сортировки по этапам: Брага, Перегонка, Выдержка, Дегустация" FontSize="14" Margin="0,5,0,0"/>
            <TextBlock Text="• Экспортируйте заметки в файл для резервного копирования" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>