<Window x:Class="VinokurnyaWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VinokurnyaWpf.Views"
        xmlns:vm="clr-namespace:VinokurnyaWpf.ViewModels"
        mc:Ignorable="d"
        Title="Винокурня — Distiller's Assistant" 
        Height="900" Width="1200"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Height="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0">
                    <Image Source="/Resources/Icons/flask.png" Width="40" Height="40" Margin="0,0,15,0"/>
                    <TextBlock Text="ВИНОКУРНЯ" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text=" — Distiller's Assistant" FontSize="16" Foreground="White" Opacity="0.8" Margin="10,0,0,0"/>
                </StackPanel>
                
                <!-- Theme Toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0">
                    <Button Command="{Binding ToggleThemeCommand}" 
                            Style="{DynamicResource MaterialDesignFlatButton}"
                            ToolTip="Сменить тему">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentTheme, Mode=OneWay}" Margin="5,0"/>
                            <Image Source="/Resources/Icons/theme.png" Width="24" Height="24"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowSettingsCommand}"
                            Style="{DynamicResource MaterialDesignFlatButton}"
                            ToolTip="Настройки">
                        <Image Source="/Resources/Icons/settings.png" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <TabControl SelectedIndex="{Binding SelectedTab, Mode=TwoWay}"
                       Style="{DynamicResource MaterialDesignTabControl}">
                <TabItem Header="🧮 Калькуляторы">
                    <local:CalculatorView/>
                </TabItem>
                
                <TabItem Header="📖 Рецепты">
                    <local:RecipesView/>
                </TabItem>
                
                <TabItem Header="📝 Заметки">
                    <local:NotesView/>
                </TabItem>
                
                <TabItem Header="📊 Статистика">
                    <local:StatisticsView/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>